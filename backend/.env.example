# App
APP_NAME="Smart Clinic Tracker"
DEBUG=false

# Database (Neon PostgreSQL — get connection string from https://neon.tech)
DATABASE_URL="postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Auth
SECRET_KEY="generate-a-random-string-at-least-32-chars"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173"]

# Cloudflare R2 (S3-compatible storage — get from Cloudflare dashboard)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="clinic-tracker"

# Resend (email — get API key from https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"
